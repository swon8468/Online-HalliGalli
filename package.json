{
  "name": "halli-galli-online",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --mode development",
    "dev:prod": "vite --mode production",
    "dev:e2e": "vite --mode e2e --host 127.0.0.1 --port 43130 --strictPort",
    "dev:connected": "vite --mode development --host 127.0.0.1 --port 43131 --strictPort",
    "build:develop": "tsc -b && vite build --mode development",
    "build": "tsc -b && vite build --mode production",
    "keys:vapid": "node scripts/generate-vapid.mjs",
    "env:migrate": "node scripts/migrate-env-files.mjs",
    "supabase:deploy:develop": "node scripts/deploy-supabase.mjs development",
    "supabase:deploy:production": "node scripts/deploy-supabase.mjs production",
    "test-users:seed": "node scripts/seed-test-users.mjs",
    "test-room:join": "node scripts/join-test-room.mjs",
    "test-room:verify": "node scripts/verify-test-room.mjs",
    "test-game:engine": "node scripts/test-game-engine.mjs",
    "test-game:completion": "node scripts/test-game-completion.mjs",
    "test-session:recovery": "node scripts/test-session-recovery.mjs",
    "test-game:multiplayer": "node scripts/test-multiplayer.mjs",
    "test-game:practice": "node --experimental-strip-types scripts/test-practice-engine.mjs",
    "test-matchmaking": "node scripts/test-matchmaking.mjs",
    "test-friends": "node scripts/test-friends.mjs",
    "test-invites": "node scripts/test-invites.mjs",
    "test-push": "node scripts/test-push.mjs",
    "test-maintenance": "node scripts/test-maintenance.mjs",
    "test-fixtures:preview": "node scripts/test-fixtures.mjs preview",
    "test-fixtures:cleanup": "node scripts/test-fixtures.mjs cleanup",
    "audit-card-assets": "node scripts/audit-card-assets.mjs preview",
    "audit-auth:develop": "node scripts/audit-supabase-auth.mjs development",
    "audit-auth:production": "node scripts/audit-supabase-auth.mjs production",
    "cleanup-test-card-assets": "node scripts/audit-card-assets.mjs cleanup-test-assets",
    "test-release-load": "node scripts/test-release-load.mjs",
    "test-account": "node scripts/test-account.mjs",
    "test-waiting-room": "node scripts/test-waiting-room.mjs",
    "test-admin": "node scripts/test-admin.mjs",
    "test-spaces": "node scripts/test-spaces.mjs",
    "test-cards": "node scripts/test-cards.mjs",
    "test-custom-card-game": "node scripts/test-custom-card-game.mjs",
    "test-game-settings": "node --experimental-strip-types scripts/test-game-settings.mjs",
    "test-game-ui-effects": "node scripts/test-game-ui-effects.mjs",
    "test-pwa": "node scripts/test-pwa.mjs",
    "test-security": "node scripts/test-security.mjs",
    "test-accessibility": "node scripts/test-accessibility.mjs",
    "test-error-messages": "node --experimental-strip-types scripts/test-error-messages.mjs",
    "test-client-id": "node --experimental-strip-types scripts/test-client-id.mjs",
    "typecheck": "tsc -b",
    "test:unit": "npm run test-game:practice && npm run test-game-settings && npm run test-game-ui-effects && npm run test-accessibility && npm run test-error-messages && npm run test-client-id",
    "test:integration": "node scripts/run-integration-tests.mjs",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:connected": "playwright test --config playwright.connected.config.ts",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.52.1",
    "lucide-react": "^0.468.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@playwright/test": "^1.61.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "eslint": "^9.30.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "supabase": "^2.109.1",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.35.1",
    "vite": "^7.0.4",
    "vite-plugin-pwa": "^1.0.1"
  }
}
